<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="dev.zicro.demo"
    android:versionCode="1"
    android:versionName="1.0">

    <uses-sdk android:minSdkVersion="29" android:targetSdkVersion="34" />

    <application android:label="zicro" android:hasCode="false">
        <activity
            android:name="android.app.NativeActivity"
            android:label="zicro"
            android:exported="true"
            android:configChanges="orientation|keyboardHidden|screenSize">
            <!-- native_app_glue's ANativeActivity_onCreate lives in libzicro.so -->
            <meta-data android:name="android.app.lib_name" android:value="zicro" />
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
